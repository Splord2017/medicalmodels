
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "medical-models/model.schema.json",
  "title": "3D Printed Medical Model Schema",
  "description": "JSON schema for validating 3D printed medical model metadata",
  "type": "object",

  "required": [
    "name",
    "license",
    "doi_nih_3dpx",
    "image_atomized",
    "image_assembly",
    "purchase_materials",
    "keywords",
    "compatible_with",
    "hazards",
    "abstract",
    "print_data",
    "print_settings"
  ],

  "properties": {

    "name": {
      "type": ["string", "null"],
      "description": "Name of the 3D printed model"
    },

    "license": {
      "type": ["string", "null"],
      "description": "License information for the model"
    },

   "doi_nih_3dpx": {
  "description": "NIH 3D Print Exchange DOI or accession identifier",
  "anyOf": [
    {
      "type": "string",
      "pattern": "^10\\.60705/3dpx/[0-9]+\\.[0-9]+$"
    },
    {
      "type": "string",
      "pattern": "^3DPX-[0-9]{6}$"
    },
    {
      "type": "null"
    }
  ]
},

    "image_atomized": {
      "type": ["array", "null"],
      "description": "Array of URLs to atomized/detailed images",
      "items": { "type": "string", "format": "uri" }
    },

    "image_assembly": {
      "type": ["array", "null"],
      "description": "Array of URLs to assembly images or videos",
      "items": { "type": "string", "format": "uri" }
    },

    "assembly_instructions": {
      "type": ["string", "null"],
      "description": "Assembly instructions, or notes not covered in the assembly images/videos"
    },

    "purchase_materials": {
      "type": ["string", "null"],
      "description": "Reference to materials purchase list"
    },

    "keywords": {
      "type": "array",
      "description": "Array of keywords and codes related to the model",
      "items": { "type": ["string", "null"] }
    },

    "compatible_with": {
      "type": "array",
      "description": "Other models with compatible modular design",
      "items": { "type": ["string", "null"] }
    },

    "hazards": {
      "type": ["array", "null"],
      "description": "Potential hazards or safety considerations",
      "items": { "type": ["string", "null"] }
    },

    "abstract": {
      "type": ["string", "null"],
      "description": "Brief description of the model"
    },

    "print_data": {
      "type": "array",
      "description": "Array of individual 3D printable components",
      "minItems": 1,

      "items": {
        "type": "object",

        "required": [
          "id",
          "name",
          "file_format",
          "file_name",
          "layer_height_mm",
          "wall_thickness_mm",
          "top_thickness_mm",
          "bottom_thickness_mm",
          "infill_percent",
          "support",
          "build_plate_adhesion_required",
          "bed_glue",
          "dimensions"
        ],

        "properties": {

          "id": { "type": ["string", "null"] },
          "name": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },

          "authors": {
            "type": "array",
            "items": { "type": ["string", "null"] },
            "minItems": 1
          },

          "creation_date": {
	   "anyOf":[
            {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
	  {
	    "type": "null"
	  }
	]
	},

          "file_format": {
            "type": ["string", "null"],
            "enum": ["STL", "OBJ", "PLY", "3MF", "AMF", "GCODE", "none", null]
          },

          "file_name": { "type": ["string", "null"] },
          "file_size_mb": { "type": ["number", "null"], "minimum": 0 },

          "atomized_model_reference": {
            "type": ["string", "number", "null"],
            "description": "Reference label linking the component to the atomized figure or file. May include numbers, letters, symbols, or other repository-specific identifiers."
          },

          "model_version": { "type": ["number", "null"], "minimum": 0 },

          "color": { "type": ["string", "null"] },

          "layer_height_mm": {
            "type": ["number", "null"],
            "minimum": 0.05,
            "maximum": 0.5
          },

          "wall_thickness_mm": { "type": ["number", "null"], "minimum": 0 },
          "wall_line_count": { "type": ["number", "null"], "minimum": 0 },

          "horizontal_expansion_mm": { "type": ["number", "null"], "minimum": 0 },

          "top_thickness_mm": { "type": ["number", "null"], "minimum": 0 },
          "top_layers_count": { "type": ["number", "null"], "minimum": 0 },

          "bottom_thickness_mm": { "type": ["number", "null"], "minimum": 0 },
          "bottom_layers_count": { "type": ["number", "null"], "minimum": 0 },

          "infill_percent": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100
          },

          "support_pattern": {
            "type": ["string", "null"],
            "enum": [
              "cubic", "lines", "triangles", "trihexagon", "grid",
              "cubicsubdivision", "octet", "quartercubic", "concentric",
              "zigzag", "cross", "cross3d", "gyroid", "lightning", "none", null
            ]
          },

          "support": {
            "type": "object",
            "properties": {
              "generate_support": { "type": ["boolean", "null"] },
              "support_structure": { "type": ["string", "null"] },
              "support_placement": { "type": ["string", "null"] },
              "support_overhang_angle_degree": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 90
              }
            }
          },

          "build_plate_adhesion_required": { "type": ["boolean", "null"] },

          "support_adhesion": { "type": ["string", "null"] },

          "bed_glue": { "type": ["boolean", "null"] },

          "dimensions": {
            "type": ["object", "null"],
            "required": [
              "length_x_mm",
              "width_y_mm",
              "height_z_mm",
              "filament_length_m",
              "filament_mass_g",
              "print_time_min",
              "print_orientation_x_axis_mm",
              "print_orientation_y_axis_mm",
              "print_orientation_z_axis_mm",
              "print_rotation_degrees"
            ],
            "properties": {
              "length_x_mm": { "type": ["number", "null"] },
              "width_y_mm": { "type": ["number", "null"] },
              "height_z_mm": { "type": ["number", "null"] },

              "filament_length_m": { "type": ["number", "null"] },
              "filament_mass_g": { "type": ["number", "null"] },
              "print_time_min": { "type": ["number", "null"] },

              "print_orientation_x_axis_mm": { "type": ["number", "null"] },
              "print_orientation_y_axis_mm": { "type": ["number", "null"] },
              "print_orientation_z_axis_mm": { "type": ["number", "null"] },

              "print_rotation_degrees": {
                "type": "object",
                "properties": {
                  "x": { "type": ["number", "null"] },
                  "y": { "type": ["number", "null"] },
                  "z": { "type": ["number", "null"] }
                }
              }
            }
          }
        }
      }
    },

    "print_settings": {
      "type": "object",

      "required": [
        "printer",
        "material",
        "material_size_mm",
        "nozzle_size_mm",
        "nozzle_temp_celsius",
        "bed_temp_celsius",
        "extrusion_path_parameters",
        "fan_speed_percent",
        "computer_aided_design_software",
        "slicer_software",
        "postprocessing"
      ],

      "properties": {

        "printer": { "type": ["string", "null"] },

        "material": {
          "type": ["array", "null"],
	  "items": { "type": "string"
	}
        },

        "material_size_mm": {
          "type": ["number", "null"],
          "enum": [1.75, 2.85, 3.0, null]
        },

        "nozzle_size_mm": {
          "type": ["number", "null"],
          "minimum": 0
        },

        "nozzle_temp_celsius": {
          "type": ["number", "null"],
          "minimum": 150,
          "maximum": 300
        },

        "bed_temp_celsius": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 150
        },

        "extrusion_path_parameters": {
          "type": "object",
          "properties": {
            "line_width": { "type": ["number", "null"], "minimum": 0 },
            "flow_percent": { "type": ["number", "null"], "minimum": 0 },
            "print_speed_mm_s": { "type": ["number", "null"], "minimum": 0 },
            "travel_speed_mm_s": { "type": ["number", "null"], "minimum": 0 },
            "initial_layer_speed_mm_s": { "type": ["number", "null"], "minimum": 0 }
          }
        },

        "fan_speed_percent": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },

        "computer_aided_design_software": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "version": {
		"anyOf": [
		{
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)*$"
		},
		{
		"type": "null"
		}
		]
            }
          }
        },

        "slicer_software": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "version": {
	    "anyOf": [
		{
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)*$"
		},
		{
		"type": "null"
		}
		]
            }
          }
        },

        "postprocessing": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        }
      }
    }
  }
}
